run = "npm start"
modules = ["nodejs-22", "postgresql-16"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[nix]
packages = ["psmisc"]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "gce"
publicDir = "public"
run = ["node", "server.js"]
