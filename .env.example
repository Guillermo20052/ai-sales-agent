# Copy to .env and fill in values. Required for local dev:
DATABASE_URL=postgresql://localhost:5432/sales_agent_saas
NODE_ENV=development

# Optional (examples):
# PORT=5000
# SESSION_SECRET=your-secret
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# AGENT_STRICT_GROUNDED=true
# AGENT_STRICT_MIN_EVIDENCE=1
# AGENT_STRICT_MIN_SCORE=0.35
# AGENT_MAX_REPLY_SOURCES=2
# AGENT_ENABLE_LIVE_NAV=true
# AGENT_LIVE_NAV_MAX_STEPS=2
# AGENT_LIVE_NAV_TIMEOUT_MS=8000
# AGENT_LIVE_NAV_TOTAL_BUDGET_MS=12000
# AGENT_MEMORY_DEFAULT_ENABLED=false
# AGENT_MEMORY_DEFAULT_RETENTION_DAYS=30
# AGENT_RETRIEVAL_CACHE_TTL_MS=45000
# AGENT_NAV_CACHE_TTL_MS=30000
# AGENT_RATE_LIMIT_PER_MIN=40
# SLA_FALLBACK_WARN_PCT=45
# SLA_ERROR_WARN_PCT=8
# SLA_P95_WARN_MS=8000
# SLA_QUEUE_WARN=25
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# BASE_URL=http://localhost:5000
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@gmail.com
# Redis (optional; when set, rate limits and login tracking are shared across instances)
# REDIS_URL=redis://localhost:6379
# USE_HTTPS=true
# AI cost protection (hourly limits when REDIS_URL set)
# AI_HOURLY_LIMIT_PER_USER=50
# AI_HOURLY_LIMIT_PER_BUSINESS=500
# AI request queue (concurrency and max pending)
# AI_QUEUE_CONCURRENCY=5
# AI_QUEUE_MAX_PENDING=100
# Training job timeout (default 2 min)
# TRAINING_JOB_TIMEOUT_MS=120000
# SITE_HELP_API_KEY=
